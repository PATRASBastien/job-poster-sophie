# Copy this file to .env and fill in the key for your chosen provider.
# Set llm.provider in config.yaml to match.

# ── Google Gemini (free tier — recommended) ──────────────────────────────────
# Get a free key at: https://aistudio.google.com/app/apikey
# No credit card required. Limit: 1 500 requests/day on gemini-2.0-flash.
GOOGLE_API_KEY=your_google_api_key_here

# ── Anthropic Claude (paid) ───────────────────────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Ollama (local, no key needed) ────────────────────────────────────────────
# Install from https://ollama.ai, then: ollama pull llama3.2
# No environment variable required.

# ── SMTP for email-mode applications (coleurope.eu uses Office 365) ──────────
# Without SMTP_PASSWORD the pipeline saves a .eml draft instead of sending.
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=sophie.patras@coleurope.eu
# SMTP_PASSWORD=your_office365_password_or_app_password
